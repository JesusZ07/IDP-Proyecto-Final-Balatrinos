<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - My ASP.NET Application</title>
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link
    href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    rel="stylesheet">
    <link
    href="https://fonts.googleapis.com/css2?family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&display=swap"
    rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
          rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap"
          rel="stylesheet">

</head>

<body class="app-shell">

    <!-- MENU PRINCIPAL -->
    <div id="menu-principal">
        <!-- LOGO HOTEL -->
        <div>
            <img src="~/Imagenes/LogoHotel.png" alt="Logo del Hotel" class="LogoHotel" />
        </div>

        <!-- OPCIONES -->
        <div id="menu-principal-opciones">
            <a href="~/Home/">Inicio</a>
            <a href="@Url.Action("Reservaciones", "Reservaciones")">Reservaciones</a>
            <a href="@Url.Action("Contacto", "Home")">Contacto</a>
        </div>

        <!-- SECCIÓN DEL USUARIO -->
        <div class="usuario" style="margin-left: auto;">
            <div>
                <label>Hola,</label>

                @if (Context.Request.Cookies.ContainsKey("UsuarioNombre"))
                {
                    <span>
                        <strong>@Context.Request.Cookies["UsuarioNombre"]</strong>
                    </span>
                    <div>
                        <a href="@Url.Action("EditarPerfil", "Cuentas")">Editar perfil</a>
                        <a href="@Url.Action("CerrarSesion", "Cuentas")">Cerrar sesión</a>
                    </div>
                }
                else
                {
                    <span><strong>Anónimo</strong></span>
                    <a href="@Url.Action("InicioSesion", "Cuentas")">Ingresar</a>
                }
            </div>

            <!-- IMAGEN DE PERFIL -->
            <div>
                <a href="@Url.Action("EditarPerfil", "Cuentas")">
                    <img src="https://picsum.photos/70/70" alt="Perfil de usuario" class="usuario-imagen" />
                </a>
            </div>
        </div>
    </div>



    <main class="page-content">
        @RenderBody()
    </main>


    <footer class="footer">
        <div class="footer-contenido">
            <div class="footer-logo">
                <h2>Hotel Oasis</h2>
                <p>Descanso, lujo y sabor en un solo lugar.</p>
            </div>

            <div class="footer-enlaces">
                <h3>Enlaces</h3>
                <ul>
                    <li><a href="@Url.Action("Index", "Home")">Inicio</a></li>
                    <li><a href="@Url.Action("Reservaciones", "Reservaciones")">Reservaciones</a></li>
                    <li><a href="@Url.Action("Contacto", "Home")">Contacto</a></li>
                </ul>
            </div>

            <div class="footer-redes">
                <h3>Síguenos</h3>
                <div class="redes">
                    <img src="~/Imagenes/icons8-facebook-96-color.png" alt="Facebook" />
                    <img src="~/Imagenes/icons8-instagram-96-color.png" alt="Instagram" />
                    <img src="~/Imagenes/icons8-whatsapp-96-color.png" alt="WhatsApp" />
                </div>
            </div>
        </div>



        <div class="footer-creditos">
            <p>&copy; 2025 Hotel Oasis. Todos los derechos reservados.</p>
        </div>
    </footer>
</body>

</html>